@model Agencija.Model.Owner

@{
    ViewData["Title"] = "Details";
}

<h2>Details</h2>

@if (Model != null)
{
    <nav aria-label== "breadcrumb">
    <ol class="breadcrumb">
        <li class= "breadcrumb-item"><a asp-action="Index">Popis vlasnika</a></li>
        <li class="breadcrumb-item active">@Model.FullName</li>
    </ol>
    </nav>



    <div>
        <h4>Vlasnik</h4>
        <hr />
        <dl class="dl-horizontal">
            <dt>
                ID
            </dt>
            <dd>
                @Html.DisplayFor(model => model.ID)
            </dd>
            <dt>
                Ime i prezime
            </dt>
            <dd>
                @Html.DisplayFor(model => model.FullName)
            </dd>
            <dt>
                Kontakt
            </dt>
            <dd>
                @Html.DisplayFor(model => model.Contact)
            </dd>
            <dt>
                Datum rođenja
            </dt>
            <dd>
                @Model?.DateOfBirth
            </dd>
            <dt>
                Datum potpisa ugovora s agencijom
            </dt>
            <dd>
                @Model?.ContractSigned
            </dd>

        </dl>

        <div>
            <a asp-action="Edit" asp-route-id="@Model.ID" class="btn btn-primary">Uredi</a>
        </div>
    </div>

}
else
{
    <div class="alert alert-danger">
        Nije odabran ispravni ID nekretnine.
    </div>

}

