@model Agencija.Model.RealEstate

@{
    ViewData["Title"] = "Uređivanje nekretnine";
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Popis nekretnina</a></li>
        <li class="breadcrumb-item active" aria-current="page">Uređivanje nekretnine</li>
    </ol>
</nav>

<div class="row">
